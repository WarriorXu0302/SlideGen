{
  "name": "ppt-html-editor",
  "version": "1.0.0",
  "description": "HTML PPT Editor with AI generation",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win --linux"
  },
  "dependencies": {
    "mammoth": "^1.8.0",
    "pdf-parse": "^1.1.1",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.ppteditor.app",
    "productName": "PPT Editor",
    "files": ["main.js", "preload.js", "renderer/**/*", "assets/**/*"],
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": [{ "target": "zip", "arch": ["x64"] }],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
